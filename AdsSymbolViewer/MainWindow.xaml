<Window x:Class="AdsSymbolViewer.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADS Symbol Viewer" Height="720" Width="1100"
        MinHeight="520" MinWidth="800"
        FontFamily="Segoe UI"
        Background="#F3F4F6"
        SnapsToDevicePixels="True" UseLayoutRounding="True"
        Closing="Window_Closing">
    <Window.Resources>

        <!-- ════════ Design tokens ════════
             Palette: Tailwind-style grays + blue/green/red accents.
             Every color in the app (including code-behind badges and
             tree type chips) comes from this set. -->
        <SolidColorBrush x:Key="Surface"       Color="#FFFFFF"/>
        <SolidColorBrush x:Key="FieldBg"       Color="#F9FAFB"/>
        <SolidColorBrush x:Key="HoverBg"       Color="#F3F4F6"/>
        <SolidColorBrush x:Key="SelectionBg"   Color="#DBEAFE"/>
        <SolidColorBrush x:Key="BorderLine"    Color="#E5E7EB"/>
        <SolidColorBrush x:Key="TextPrimary"   Color="#111827"/>
        <SolidColorBrush x:Key="TextSecondary" Color="#4B5563"/>
        <SolidColorBrush x:Key="TextSoft"      Color="#6B7280"/>
        <SolidColorBrush x:Key="TextMuted"     Color="#9CA3AF"/>
        <SolidColorBrush x:Key="Primary"       Color="#2563EB"/>
        <SolidColorBrush x:Key="PrimaryHover"  Color="#1D4ED8"/>
        <SolidColorBrush x:Key="Success"       Color="#16A34A"/>
        <SolidColorBrush x:Key="SuccessHover"  Color="#15803D"/>
        <SolidColorBrush x:Key="Danger"        Color="#DC2626"/>
        <SolidColorBrush x:Key="DangerHover"   Color="#B91C1C"/>
        <SolidColorBrush x:Key="NeutralChip"   Color="#E5E7EB"/>

        <!-- ════════ Typography ════════ -->
        <Style x:Key="SectionTitle" TargetType="TextBlock">
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
        </Style>

        <Style x:Key="Lbl" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextSoft}"/>
            <Setter Property="FontSize"   Value="10"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Margin"     Value="0,0,0,4"/>
        </Style>

        <!-- ════════ Buttons ════════
             Background = rest color, Tag = hover color. -->
        <Style x:Key="BtnBase" TargetType="Button">
            <Setter Property="Foreground"      Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="14,6"/>
            <Setter Property="MinHeight"       Value="30"/>
            <Setter Property="FontSize"        Value="12"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="Cursor"          Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="5" Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Background"
                                        Value="{Binding Tag, RelativeSource={RelativeSource TemplatedParent}}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BtnPrimary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Primary}"/>
            <Setter Property="Tag"        Value="{StaticResource PrimaryHover}"/>
        </Style>
        <Style x:Key="BtnSuccess" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Success}"/>
            <Setter Property="Tag"        Value="{StaticResource SuccessHover}"/>
        </Style>
        <Style x:Key="BtnDanger" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background" Value="{StaticResource Danger}"/>
            <Setter Property="Tag"        Value="{StaticResource DangerHover}"/>
        </Style>
        <Style x:Key="BtnSecondary" TargetType="Button" BasedOn="{StaticResource BtnBase}">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="Tag"             Value="{StaticResource HoverBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSecondary}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
        </Style>

        <!-- ════════ Toggles ════════ -->
        <Style x:Key="PillToggle" TargetType="ToggleButton">
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
            <Setter Property="FontSize"   Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding"    Value="10,5"/>
            <Setter Property="Cursor"     Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ToggleButton">
                        <Border x:Name="bd" CornerRadius="5"
                                Background="{StaticResource NeutralChip}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsChecked" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource Success}"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="bd" Property="Opacity" Value="0.85"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="BoolToggle" TargetType="ToggleButton" BasedOn="{StaticResource PillToggle}">
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="Padding"  Value="18,6"/>
            <Setter Property="HorizontalAlignment" Value="Left"/>
        </Style>

        <!-- ════════ TextBoxes ════════ -->
        <Style x:Key="TbEdit" TargetType="TextBox">
            <Setter Property="Background"  Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderLine}"/>
            <Setter Property="Foreground"  Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"    Value="13"/>
            <Setter Property="Padding"     Value="8,6"/>
            <Setter Property="MinHeight"   Value="32"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border x:Name="bd" Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="1" CornerRadius="5">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}"
                                          VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsKeyboardFocusWithin" Value="True">
                                <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="bd" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="TbRO" TargetType="TextBox" BasedOn="{StaticResource TbEdit}">
            <Setter Property="IsReadOnly" Value="True"/>
            <Setter Property="Background" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground" Value="{StaticResource TextSecondary}"/>
        </Style>

        <!-- ════════ ComboBox ════════ -->
        <Style TargetType="ComboBoxItem">
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBoxItem">
                        <Border x:Name="bd" Padding="9,6" Background="Transparent">
                            <ContentPresenter/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsHighlighted" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource HoverBg}"/>
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="bd" Property="Background" Value="{StaticResource SelectionBg}"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="MinHeight"  Value="32"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="ComboBox">
                        <Grid x:Name="root">
                            <ToggleButton x:Name="toggle" Focusable="False" ClickMode="Press"
                                          IsChecked="{Binding IsDropDownOpen, Mode=TwoWay,
                                                      RelativeSource={RelativeSource TemplatedParent}}">
                                <ToggleButton.Template>
                                    <ControlTemplate TargetType="ToggleButton">
                                        <Border x:Name="tbd" Background="{StaticResource Surface}"
                                                BorderBrush="{StaticResource BorderLine}"
                                                BorderThickness="1" CornerRadius="5">
                                            <Path HorizontalAlignment="Right" VerticalAlignment="Center"
                                                  Margin="0,0,10,0" Width="8" Height="5"
                                                  Data="M 0 0 L 4 4 L 8 0"
                                                  Stroke="{StaticResource TextSoft}" StrokeThickness="1.5"/>
                                        </Border>
                                        <ControlTemplate.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter TargetName="tbd" Property="BorderBrush" Value="{StaticResource TextMuted}"/>
                                            </Trigger>
                                            <Trigger Property="IsChecked" Value="True">
                                                <Setter TargetName="tbd" Property="BorderBrush" Value="{StaticResource Primary}"/>
                                            </Trigger>
                                        </ControlTemplate.Triggers>
                                    </ControlTemplate>
                                </ToggleButton.Template>
                            </ToggleButton>

                            <ContentPresenter x:Name="contentSite" IsHitTestVisible="False"
                                              Margin="9,0,28,0" VerticalAlignment="Center"
                                              Content="{TemplateBinding SelectionBoxItem}"
                                              ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"/>

                            <TextBox x:Name="PART_EditableTextBox" Visibility="Collapsed"
                                     Margin="9,0,28,0" Padding="0"
                                     Background="Transparent" BorderThickness="0"
                                     VerticalContentAlignment="Center"
                                     Foreground="{TemplateBinding Foreground}"/>

                            <Popup x:Name="PART_Popup" Placement="Bottom" AllowsTransparency="True"
                                   IsOpen="{TemplateBinding IsDropDownOpen}" PopupAnimation="Fade">
                                <Border Background="{StaticResource Surface}"
                                        BorderBrush="{StaticResource BorderLine}"
                                        BorderThickness="1" CornerRadius="5"
                                        Margin="0,3,8,8"
                                        MinWidth="{Binding ActualWidth, RelativeSource={RelativeSource TemplatedParent}}"
                                        MaxHeight="{TemplateBinding MaxDropDownHeight}">
                                    <Border.Effect>
                                        <DropShadowEffect BlurRadius="8" ShadowDepth="2"
                                                          Opacity="0.15" Direction="270"/>
                                    </Border.Effect>
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Popup>
                        </Grid>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsEditable" Value="True">
                                <Setter TargetName="PART_EditableTextBox" Property="Visibility" Value="Visible"/>
                                <Setter TargetName="contentSite" Property="Visibility" Value="Hidden"/>
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="root" Property="Opacity" Value="0.45"/>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ════════ Card ════════ -->
        <Style x:Key="Card" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource Surface}"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderLine}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius"    Value="8"/>
            <Setter Property="Padding"         Value="16"/>
        </Style>

        <!-- ════════ TreeView ════════ -->
        <Style TargetType="TreeView">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Background"      Value="Transparent"/>
        </Style>
        <Style TargetType="TreeViewItem">
            <Setter Property="Padding"    Value="3,3"/>
            <Setter Property="FontSize"   Value="13"/>
            <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBg}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- ════════ DataGrid ════════ -->
        <Style TargetType="DataGrid">
            <Setter Property="BorderThickness"          Value="0"/>
            <Setter Property="GridLinesVisibility"      Value="Horizontal"/>
            <Setter Property="HorizontalGridLinesBrush" Value="{StaticResource BorderLine}"/>
            <Setter Property="Background"               Value="{StaticResource Surface}"/>
            <Setter Property="RowBackground"            Value="{StaticResource Surface}"/>
            <Setter Property="AlternatingRowBackground" Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground"               Value="{StaticResource TextPrimary}"/>
            <Setter Property="FontSize"                 Value="12"/>
            <Setter Property="CanUserAddRows"           Value="False"/>
            <Setter Property="CanUserDeleteRows"        Value="False"/>
            <Setter Property="AutoGenerateColumns"      Value="False"/>
            <Setter Property="SelectionMode"            Value="Single"/>
            <Setter Property="HeadersVisibility"        Value="Column"/>
        </Style>
        <Style TargetType="DataGridColumnHeader">
            <Setter Property="Background"      Value="{StaticResource FieldBg}"/>
            <Setter Property="Foreground"      Value="{StaticResource TextSoft}"/>
            <Setter Property="FontWeight"      Value="SemiBold"/>
            <Setter Property="FontSize"        Value="11"/>
            <Setter Property="Padding"         Value="8,7"/>
            <Setter Property="BorderBrush"     Value="{StaticResource BorderLine}"/>
            <Setter Property="BorderThickness" Value="0,0,0,1"/>
        </Style>
        <Style TargetType="DataGridCell">
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding"         Value="8,5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="DataGridCell">
                        <Border Padding="{TemplateBinding Padding}"
                                Background="{TemplateBinding Background}">
                            <ContentPresenter VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsSelected" Value="True">
                    <Setter Property="Background" Value="{StaticResource SelectionBg}"/>
                    <Setter Property="Foreground" Value="{StaticResource TextPrimary}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

    </Window.Resources>

    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <!-- connection bar -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="*"/>
            <!-- main -->
            <RowDefinition Height="10"/>
            <RowDefinition Height="115"/>
            <!-- log -->
        </Grid.RowDefinitions>

        <!-- ══════════════════════════════════════════════
             ROW 0 – Connection Bar
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="0" Style="{StaticResource Card}" Padding="16,12">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="190"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="90"/>
                    <ColumnDefinition Width="12"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="10"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="16"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock Grid.Column="0" Text="NETID" Style="{StaticResource Lbl}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <ComboBox Grid.Column="1" x:Name="cbNetId" IsEditable="True"
                          SelectionChanged="cbNetId_SelectionChanged"/>

                <TextBlock Grid.Column="3" Text="PORT" Style="{StaticResource Lbl}"
                           VerticalAlignment="Center" Margin="0,0,8,0"/>

                <ComboBox Grid.Column="4" x:Name="cbPort" IsEditable="True">
                    <ComboBoxItem Content="851"   IsSelected="True"/>
                    <ComboBoxItem Content="852"/>
                    <ComboBoxItem Content="801"/>
                    <ComboBoxItem Content="811"/>
                    <ComboBoxItem Content="10000"/>
                </ComboBox>

                <Button Grid.Column="6" x:Name="btnConnect"
                        Content="Connect" Style="{StaticResource BtnPrimary}"
                        MinWidth="100" Click="btnConnect_Click"/>

                <Button Grid.Column="8" x:Name="btnLoadSymbols"
                        Content="Load Symbols" Style="{StaticResource BtnSecondary}"
                        IsEnabled="False" Click="btnLoadSymbols_Click"/>

                <!-- ADS State badge -->
                <StackPanel Grid.Column="10" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="ADS" Style="{StaticResource Lbl}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <Border x:Name="bdAds" Background="{StaticResource NeutralChip}" CornerRadius="4" Padding="10,4">
                        <TextBlock x:Name="tbAds" Text="—" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSoft}"/>
                    </Border>
                </StackPanel>

                <!-- Conn State badge -->
                <StackPanel Grid.Column="12" Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="CONN" Style="{StaticResource Lbl}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <Border x:Name="bdConn" Background="{StaticResource NeutralChip}" CornerRadius="4" Padding="10,4">
                        <TextBlock x:Name="tbConn" Text="—" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextSoft}"/>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ══════════════════════════════════════════════
             ROW 2 – Main Content
        ══════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="310" MinWidth="180"/>
                <ColumnDefinition Width="10"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ── Left: Symbol Tree ── -->
            <Border Grid.Column="0" Style="{StaticResource Card}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="10"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Text="Symbol Tree" Style="{StaticResource SectionTitle}"/>

                    <!-- Filter box -->
                    <Border Grid.Row="2" BorderBrush="{StaticResource BorderLine}" BorderThickness="1"
                            CornerRadius="5" Background="{StaticResource Surface}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="🔍" VerticalAlignment="Center"
                                       Margin="8,0,5,0" FontSize="11"/>
                            <Grid Grid.Column="1">
                                <TextBox x:Name="tbFilter" BorderThickness="0"
                                         Padding="0,7" FontSize="12" Background="Transparent"
                                         Foreground="{StaticResource TextPrimary}"
                                         TextChanged="tbFilter_TextChanged"/>
                                <TextBlock x:Name="tbFilterPlaceholder"
                                           Text="Filter symbols…" Foreground="{StaticResource TextMuted}"
                                           FontSize="12" VerticalAlignment="Center"
                                           Margin="2,0,0,0" IsHitTestVisible="False"/>
                            </Grid>
                        </Grid>
                    </Border>

                    <!-- Tree -->
                    <ScrollViewer Grid.Row="4"
                                  VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Auto">
                        <TreeView x:Name="tvSymbols"
                                  SelectedItemChanged="tvSymbols_SelectedItemChanged"/>
                    </ScrollViewer>

                    <Button Grid.Row="6" Content="Export CSV"
                            Style="{StaticResource BtnSecondary}"
                            HorizontalAlignment="Right"
                            Click="btnExportCsv_Click"/>
                </Grid>
            </Border>

            <GridSplitter Grid.Column="1" Width="10"
                          HorizontalAlignment="Stretch" Background="Transparent"/>

            <!-- ── Right: Detail + Watch ── -->
            <Grid Grid.Column="2">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="10"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Symbol Detail Card -->
                <Border Grid.Row="0" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="12"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Text="Symbol Detail" Style="{StaticResource SectionTitle}"/>

                        <!-- Row 1: Name + Type + Size + IG -->
                        <Grid Grid.Row="2">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="120"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="70"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="115"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="115"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0">
                                <TextBlock Text="NAME" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbName" Style="{StaticResource TbRO}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="TYPE" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbTypeName" Style="{StaticResource TbRO}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="4">
                                <TextBlock Text="SIZE" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbSize" Style="{StaticResource TbRO}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="6">
                                <TextBlock Text="INDEX GRP" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbIndexGroup" Style="{StaticResource TbRO}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="8">
                                <TextBlock Text="INDEX OFS" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbIndexOffset" Style="{StaticResource TbRO}"/>
                            </StackPanel>
                        </Grid>

                        <!-- Row 2: Value -->
                        <Grid Grid.Row="4">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="VALUE" Style="{StaticResource Lbl}"/>
                                <TextBox x:Name="tbValue" Style="{StaticResource TbEdit}"/>
                                <ToggleButton x:Name="chkBool"
                                              Style="{StaticResource BoolToggle}"
                                              Visibility="Collapsed" Height="32" Content="FALSE"
                                              Checked="chkBool_Changed" Unchecked="chkBool_Changed"/>
                                <ComboBox x:Name="cbEnum" Visibility="Collapsed"
                                          SelectionChanged="cbEnum_SelectionChanged"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2" Orientation="Horizontal"
                                        VerticalAlignment="Bottom">
                                <Button x:Name="btnRead" Content="Read"
                                        Style="{StaticResource BtnSecondary}"
                                        IsEnabled="False" Margin="0,0,8,0"
                                        Click="btnRead_Click"/>
                                <Button x:Name="btnWrite" Content="Write"
                                        Style="{StaticResource BtnSuccess}"
                                        IsEnabled="False" Margin="0,0,8,0"
                                        Click="btnWrite_Click"/>
                                <Button x:Name="btnAddToWatch" Content="+ Watch"
                                        Style="{StaticResource BtnPrimary}"
                                        IsEnabled="False"
                                        Click="btnAddToWatch_Click"/>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>

                <!-- Watch List Card -->
                <Border Grid.Row="2" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="10"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Watch header row -->
                        <Grid Grid.Row="0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="10"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="8"/>
                                <ColumnDefinition Width="85"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0" Text="Watch List"
                                       Style="{StaticResource SectionTitle}" VerticalAlignment="Center"/>

                            <ToggleButton Grid.Column="2" x:Name="tglRefresh"
                                          Style="{StaticResource PillToggle}"
                                          Content="⏸ Stopped"
                                          Checked="tglRefresh_Checked"
                                          Unchecked="tglRefresh_Unchecked"/>

                            <TextBlock Grid.Column="4" Text="INTERVAL"
                                       Style="{StaticResource Lbl}" Margin="0"
                                       VerticalAlignment="Center"/>

                            <ComboBox Grid.Column="6" x:Name="cbInterval"
                                      FontSize="12" MinHeight="28"
                                      SelectionChanged="cbInterval_SelectionChanged">
                                <ComboBoxItem Content="200 ms"  Tag="200"/>
                                <ComboBoxItem Content="500 ms"  Tag="500" IsSelected="True"/>
                                <ComboBoxItem Content="1 s"     Tag="1000"/>
                                <ComboBoxItem Content="2 s"     Tag="2000"/>
                                <ComboBoxItem Content="5 s"     Tag="5000"/>
                            </ComboBox>
                        </Grid>

                        <!-- Watch DataGrid -->
                        <DataGrid Grid.Row="2" x:Name="dgWatch">
                            <DataGrid.Columns>
                                <DataGridTextColumn Header="Name"   Binding="{Binding Name}"      Width="*"/>
                                <DataGridTextColumn Header="Type"   Binding="{Binding TypeName}"  Width="80"/>
                                <DataGridTextColumn Header="Value"  Binding="{Binding Value}"     Width="130"/>
                                <DataGridTextColumn Header="Time"   Binding="{Binding Timestamp}" Width="70"/>
                            </DataGrid.Columns>
                        </DataGrid>

                        <Button Grid.Row="4" Content="Remove Selected"
                                Style="{StaticResource BtnDanger}"
                                HorizontalAlignment="Right"
                                Padding="10,5" FontSize="11"
                                Click="btnRemoveWatch_Click"/>
                    </Grid>
                </Border>
            </Grid>
        </Grid>

        <!-- ══════════════════════════════════════════════
             ROW 4 – Log
        ══════════════════════════════════════════════ -->
        <Border Grid.Row="4" Style="{StaticResource Card}" Padding="16,10,16,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="6"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>
                <Grid Grid.Row="0">
                    <TextBlock Text="LOG" Style="{StaticResource Lbl}" Margin="0" VerticalAlignment="Center"/>
                    <Button Content="Clear" HorizontalAlignment="Right"
                            Style="{StaticResource BtnSecondary}"
                            FontSize="11" Padding="8,3" MinHeight="0"
                            Click="btnClearLog_Click"/>
                </Grid>
                <TextBox Grid.Row="2" x:Name="tbLog"
                         IsReadOnly="True"
                         FontFamily="Consolas" FontSize="11"
                         Foreground="{StaticResource TextSecondary}" Background="Transparent"
                         BorderThickness="0"
                         VerticalScrollBarVisibility="Auto"
                         TextWrapping="NoWrap"/>
            </Grid>
        </Border>
    </Grid>
</Window>
